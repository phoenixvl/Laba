#include <stdio.h>
 
#define FIND_MAX(arr, n, max) {     \
    max = arr[0];                   \
    for (int i = 1; i < n; i++)    \
        if (arr[i] > max)           \
            max = arr[i];           \
}
 
int main() {
    int arr[100], n = 0;
    char line[1024];
 
    printf("Числа: ");
    fgets(line, sizeof(line), stdin);
 
    char *p = line;
    while (sscanf(p, "%d", &arr[n]) == 1) {
        while (*p == ' ') p++;
        while (*p && *p != ' ') p++;
        n++;
    }
 
    int max;
    FIND_MAX(arr, n, max);
 
    printf("Максимальное число: %d\n", max);
    return 0;
}
