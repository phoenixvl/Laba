#include <signal.h>
#include <stdio.h>
#include <stdlib.h>
void handler(int sig) {
    switch (sig) {
        case SIGABRT: printf ("Signal received by SIGABRT\n"); break;
        case SIGFPE: printf ("Signal received by SIGFPE\n"); break;
        case SIGILL: printf ("Signal received by SIGILL\n"); break;
        case SIGINT: printf ("Signal received by SIGINT\n"); break;
        case SIGSEGV: printf ("Signal received by SIGSEGV\n"); break;
        case SIGTERM: printf ("Signal received by SIGTERM\n"); break;
    }
}

int main() {
