#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int main() {
    char str[256], *token;
    double result = 0;
    char op = '+';

    printf("Numbers: ");
    fgets(str, 256, stdin);

    token = strtok(str, " \n");

    while (token != NULL) {
        if (token[0] == '+' || token[0] == '-') {
            op = token[0];
        } else {
            if (op == '+')
                result += atof(token);
            else
                result -= atof(token);
        }
        token = strtok(NULL, " \n");
    }

    printf("Результат: %g\n", result);
    return 0;
}
