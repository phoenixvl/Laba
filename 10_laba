#include <stdio.h>
#include <string.h>
#include <stdlib.h>

// Макрос для нахождения максимального числа в массиве
#define MAX_NUMBERS(arr, n) ({ \
    int max = arr[0]; \
    for(int i = 1; i < n; i++) { \
        if(arr[i] > max) max = arr[i]; \
    } \
    max; \
})

int main() {
    char input[1000];
    int numbers[100];
    int count = 0;
    
    printf("Введите числа через пробел: ");
    fgets(input, sizeof(input), stdin);
    
    // Разбиваем строку на числа
    char *token = strtok(input, " \n");
    while(token != NULL && count < 100) {
        numbers[count++] = atoi(token);
        token = strtok(NULL, " \n");
    }
    
    if(count == 0) {
        printf("Числа не введены!\n");
        return 1;
    }
    
    // Вызываем макрос
    int max = MAX_NUMBERS(numbers, count);
    
    printf("Максимальное число: %d\n", max);
    
    return 0;
}
