#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define FIND_MAX(arr, n) ({   \
long long max = (arr)[0];      \
int i;                   \
for (i = 1; i < (n); i++) \
if ((arr)[i] > max)   \
    max = (arr)[i];    \
max;                     \
})

int main() {
    char line[1000];
    long long nums[100];
    int n = 0;
    printf ("Numbers: ");
    fgets(line, sizeof(line), stdin);
    char *token = strtok(line, " ");
    while (token != NULL) {
        nums[n] = atoll(token);
        n++;
        token = strtok(NULL, " ");
    }
    long long maximum = FIND_MAX(nums, n);
    printf("Max: %lld\n", maximum);
    return 0;
}
