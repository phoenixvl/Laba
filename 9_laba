#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

#define MAX_INPUT 1024
#define MAX_TOKENS 256

/* ─── Токенизация ────────────────────────────────────────────────────────────
 *
 * Проблема strtok: он удаляет разделители, поэтому знак числа (-123)
 * неотличим от бинарного минуса.
 *
 * Решение: перед разбивкой вставляем пробел перед каждым '+'/'-',
 * если это БИНАРНЫЙ оператор (предыдущий символ — цифра, '.' или ')').
 * После strtok знак при числе сохраняется как часть токена.
 *
 * Примеры:
 *   "-123.5+4-456+56"  →  "-123.5 +4 -456 +56"
 *   токены: ["-123.5"] ["+4"] ["-456"] ["+56"]
 *
 *   "10 + -3"          →  "10  + -3"
 *   токены: ["10"] ["+"] ["-3"]           ← "+" и "-3" — отдельные
 * ─────────────────────────────────────────────────────────────────────────── */

/* Возвращает 1, если символ может заканчивать число или закрытую скобку */
static int is_number_end(char c) {
    return isdigit((unsigned char)c) || c == '.' || c == ')';
}

/* Вставляет пробелы перед бинарными '+'/'-' → новая строка в buf */
static void preprocess(const char *src, char *buf, int bufsize) {
    int j = 0;
    for (int i = 0; src[i] && j < bufsize - 2; i++) {
        char c = src[i];
        if ((c == '+' || c == '-') && i > 0 && is_number_end(src[i - 1])) {
            buf[j++] = ' ';   /* отбиваем бинарный оператор пробелом */
        }
        buf[j++] = c;
    }
    buf[j] = '\0';
}

/* ─── Вычисление ─────────────────────────────────────────────────────────── */

/*
 * Логика разбора токенов:
 *
 *  Токен — это строка без пробелов после strtok(" ").
 *  Возможные формы токена:
 *
 *    a) число с необязательным знаком: "-123.5", "+4", "56"
 *       → просто atof(), прибавляем к result
 *
 *    b) одиночный оператор без числа: "+" или "-"
 *       → запоминаем его в pending_op,
 *         следующий токен (число без знака) применяем с этим оператором
 *
 *  Алгоритм:
 *    result = 0
 *    pending_op = '+'     ← по умолчанию "прибавить"
 *    для каждого токена:
 *      если токен == "+" или "-": pending_op = токен[0]
 *      иначе: result = result (pending_op) atof(токен)
 *             pending_op = '+'  ← знак токена уже учтён в числе
 */
static int evaluate(const char *expr, double *result) {
    char buf[MAX_INPUT];
    char tmp[MAX_INPUT];

    preprocess(expr, buf, sizeof(buf));
    strncpy(tmp, buf, sizeof(tmp));
    tmp[sizeof(tmp) - 1] = '\0';

    *result = 0.0;
    char pending_op = '+';
    int  got_number = 0;   /* получили ли хоть одно число */

    char *tok = strtok(tmp, " \t");
    while (tok) {
        /* Пропускаем пустые токены (если несколько пробелов подряд) */
        if (tok[0] == '\0') { tok = strtok(NULL, " \t"); continue; }

        /* Одиночный оператор? */
        if ((tok[0] == '+' || tok[0] == '-') && tok[1] == '\0') {
            pending_op = tok[0];
            tok = strtok(NULL, " \t");
            continue;
        }

        /* Проверяем, что токен — допустимое число */
        char *endptr;
        double val = strtod(tok, &endptr);
        if (endptr == tok || *endptr != '\0') {
            fprintf(stderr, "Ошибка: недопустимый токен \"%s\"\n", tok);
            return 0;
        }

        /* Применяем pending_op */
        if (!got_number) {
            *result = val;     /* первый операнд: унарный '+'/'-' уже в val */
            got_number = 1;
        } else {
            if (pending_op == '+') *result += val;
            else                   *result -= val;
        }
        pending_op = '+';   /* сбрасываем: знак числа уже учтён */

        tok = strtok(NULL, " \t");
    }

    if (!got_number) {
        fprintf(stderr, "Ошибка: выражение не содержит чисел\n");
        return 0;
    }
    return 1;
}

/* ─── Вспомогательное: красивый вывод числа ─────────────────────────────── */
static void print_result(double v) {
    /* Если дробная часть нулевая — выводим как целое */
    if (v == (long long)v)
        printf("Результат: %lld\n", (long long)v);
    else
        printf("Результат: %g\n", v);
}

/* ─── main ───────────────────────────────────────────────────────────────── */
int main(void) {
    char input[MAX_INPUT];

    printf("Калькулятор (операции + и -, унарный и бинарный вариант)\n");
    printf("Для выхода введите 'exit' или 'q'\n");
    printf("─────────────────────────────────────────────────────────\n");

    while (1) {
        printf("\nВыражение: ");
        if (!fgets(input, sizeof(input), stdin)) break;

        /* Убираем символ новой строки */
        input[strcspn(input, "\n")] = '\0';

        /* Пропускаем пустой ввод */
        if (input[0] == '\0') continue;

        /* Команда выхода */
        if (strcmp(input, "exit") == 0 || strcmp(input, "q") == 0) {
            printf("Выход.\n");
            break;
        }

        double result;
        if (evaluate(input, &result))
            print_result(result);
    }

    return 0;
}
