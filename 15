#include <stdio.h>

int main(void) {
   int n;
    int i;
    int count=0;
    int num=0;
    printf("Enter a number: ");
   scanf("%d", &n);
    if (n <= 0) {
        printf("error");
    }
    num = n;
    int arr[n];
    i = 0;
    while (n > 0) {
        arr[i] = n%10;
        n /= 10;
        i++;
    }
    count=i;
    for (i = 0; i < count; i++) {
        printf(" %d", arr[count - i - 1]);
    }
    printf("\n");
    while (num > 0) {
    printf(" %d", num%10);
    num = num/10;
    }

    return 0;
}
